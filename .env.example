# Fox-Pinterest Environment Configuration
# Copy this file to .env and fill in your Pinterest API credentials.
# NEVER commit the .env file to version control.

# Pinterest App Credentials (from developers.pinterest.com)
PINTEREST_APP_ID=your_app_id_here
PINTEREST_APP_SECRET=your_secret_here
# OAuth redirect URI
PINTEREST_REDIRECT_URI=https://localhost:8080/callback
